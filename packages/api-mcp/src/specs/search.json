ies":{"tokenCount":{"type":"number"},"poolCount":{"type":"number"},"lastSyncTime":{"type":"string","nullable":true},"syncInProgress":{"type":"boolean"}},"required":["tokenCount","poolCount","lastSyncTime","syncInProgress"]}}}}}}},"/api/v1/autocomplete":{"get":{"tags":["Search"],"summary":"Get autocomplete suggestion","description":"Fast autocomplete endpoint optimized for high traffic. Returns the top matching token symbol for prefix completion.","parameters":[{"schema":{"type":"string","minLength":1,"maxLength":256,"description":"Search query prefix","example":"ET"},"required":true,"description":"Search query prefix","name":"q","in":"query"},{"schema":{"type":"string","description":"Filter by chain ID","example":"4326"},"required":false,"description":"Filter by chain ID","name":"chainId","in":"query"}],"responses":{"200":{"description":"Autocomplete suggestion","content":{"application/json":{"schema":{"type":"object","properties":{"suggestion":{"type":"object","nullable":true,"properties":{"completion":{"type":"string","description":"The full text to complete to (symbol or name)"},"symbol":{"type":"string"},"name":{"type":"string"},"address":{"type":"string"},"matchType":{"type":"string","enum":["symbol","name"],"description":"Whether the completion matched the symbol or name"}},"required":["completion","symbol","name","address","matchType"]},"query":{"type":"string"}},"required":["suggestion","query"]}}}}}}},"/api/v1/tokens":{"get":{"tags":["Tokens"],"summary":"List tokens","description":"List tokens without search query. Use filter params to narrow by labels like bluechip, trending, etc. Use filterMode=or to match ANY filter instead of ALL.","parameters":[{"schema":{"type":"string","description":"Filter by chain ID","example":"4326"},"required":false,"description":"Filter by chain ID","name":"chainId","in":"query"},{"schema":{"type":"string","default":"20","description":"Maximum results (1-100, default 20)","example":"20"},"required":false,"description":"Maximum results (1-100, default 20)","name":"limit","in":"query"},{"schema":{"type":"string","description":"Filter by bluechip status"},"required":false,"description":"Filter by bluechip status","name":"isBluechip","in":"query"},{"schema":{"type":"string","description":"Filter by trending status"},"required":false,"description":"Filter by trending status","name":"isTrending","in":"query"},{"schema":{"type":"string","description":"Filter by Fire protocol status"},"required":false,"description":"Filter by Fire protocol status","name":"isFireToken","in":"query"},{"schema":{"type":"string","description":"Filter by verified status"},"required":false,"description":"Filter by verified status","name":"isVerified","in":"query"},{"schema":{"type":"string","enum":["verified","trusted","all"],"description":"Visibility filter: 'verified' = bluechip + verified only, 'trusted' = bluechip + verified + fire protocol, 'all' = no filtering"},"required":false,"description":"Visibility filter: 'verified' = bluechip + verified only, 'trusted' = bluechip + verified + fire protocol, 'all' = no filtering","name":"visibility","in":"query"},{"schema":{"type":"string","enum":["and","or"],"default":"and","description":"Filter mode: 'and' requires all conditions, 'or' requires any condition"},"required":false,"description":"Filter mode: 'and' requires all conditions, 'or' requires any condition","name":"filterMode","in":"query"}],"responses":{"200":{"description":"Token list","content":{"application/json":{"schema":{"type":"object","properties":{"tokens":{"type":"array","items":{"type":"object","properties":{"id":{"type":"string"},"address":{"type":"string"},"symbol":{"type":"string"},"name":{"type":"string"},"chainId":{"type":"number"},"decimals":{"type":"number"},"totalValueLockedUSD":{"type":"string"},"volumeUSD":{"type":"string"},"isBluechip":{"type":"boolean"},"isTrending":{"type":"boolean"},"isFireToken":{"type":"boolean"},"isVerified":{"type":"boolean"},"fireCreator":{"type":"string","nullable":true},"fireGraduated":{"type":"boolean","nullable":true},"imageUrl":{"type":"string","nullable":true}},"required":["id","address","symbol","name","chainId","decimals","totalValueLockedUSD","volumeUSD","isBluechip","isTrending","isFireToken","isVerified","fireCreator","fireGraduated","imageUrl"]}},"chainId":{"type":"number"}},"required":["tokens"]}}}}}}}}}