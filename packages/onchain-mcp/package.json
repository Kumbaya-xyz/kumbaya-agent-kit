{
  "name": "@kumbaya_xyz/onchain-mcp",
  "version": "0.1.0",
  "description": "MCP server for on-chain Kumbaya actions on MegaETH — swap, liquidity, token launch (Fire), tips, and reads. Signs with a wallet key you control.",
  "type": "module",
  "bin": {
    "kumbaya-onchain-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/reads.test.ts test/mcp.test.ts",
    "test:write": "node --env-file=.env --import tsx --test --test-concurrency=1 test/writes.test.ts test/wallet.test.ts"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@kumbaya_xyz/router-sdk": "^1.17.3",
    "@kumbaya_xyz/sdk-core": "^7.12.2",
    "@kumbaya_xyz/v3-sdk": "^3.15.5",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ethers": "^5.8.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0"
  }
}
