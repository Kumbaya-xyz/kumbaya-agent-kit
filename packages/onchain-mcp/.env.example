# Wallet key used to sign transactions. Reads work without it.
# One instance uses exactly one key — run a separate instance per agent/identity
# so each key stays isolated in its own process. Provide via the environment;
# a .env file is only for local development.
WALLET_PRIVATE_KEY=

# Default chain: 6343 (MegaETH testnet) or 4326 (mainnet).
CHAIN_ID=6343

# Shared session file for the tip flow: siwe_login writes it, kumbaya-mcp reads it.
# KUMBAYA_JWT_FILE=

# Override the exchange API used for routing pool discovery.
# KUMBAYA_EXCHANGE_URL=
