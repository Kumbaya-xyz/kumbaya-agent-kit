# Signing: use EITHER a local key (single wallet) OR a remote signer (agent fleets).

# Local mode — a wallet key in this process. Reads work without it.
WALLET_PRIVATE_KEY=

# Remote mode — delegate signing to @kumbaya_xyz/onchain-signer; this process holds no key.
# Each agent points at the shared signer with its own token. SIGNER_ADDRESS is optional:
# when omitted, the address is derived from the signer's /v1/address at startup.
# SIGNER_URL=http://localhost:8787
# SIGNER_TOKEN=
# SIGNER_ADDRESS=

# Default chain: 6343 (MegaETH testnet) or 4326 (mainnet).
CHAIN_ID=6343

# Shared session file for the tip flow: siwe_login writes it, kumbaya-mcp reads it.
# KUMBAYA_JWT_FILE=

# Override the exchange API used for routing pool discovery.
# KUMBAYA_EXCHANGE_URL=

# Override the search API used to classify tokens as launchpad, bluechip, or verified.
# KUMBAYA_SEARCH_URL=

# Override the block explorers used to discover an address's token holdings.
# KUMBAYA_BLOCKSCOUT_4326=
# KUMBAYA_BLOCKSCOUT_6343=
