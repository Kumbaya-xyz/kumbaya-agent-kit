{
  "name": "@kumbaya_xyz/onchain-signer",
  "version": "0.2.1",
  "description": "Per-agent signing service for Kumbaya on-chain actions. Holds keys server-side; signs JWT/token-authenticated requests so agent processes never hold raw keys.",
  "type": "module",
  "bin": {
    "kumbaya-onchain-signer": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kumbaya-xyz/kumbaya-agent-kit.git",
    "directory": "packages/signer"
  },
  "homepage": "https://github.com/Kumbaya-xyz/kumbaya-agent-kit/tree/main/packages/signer#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0"
  }
}
