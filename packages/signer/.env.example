# Token -> key map (or use SIGNER_KEYS_FILE for a JSON file). Policy fields are optional;
# allowTypedData restricts EIP-712 signing (defaults to the FuelVault GiftPermit only).
# { "<token>": { "key": "0x..", "label": "..", "policy": { "allowChains": [6343], "maxValueWei": "..", "allowTo": ["0x.."], "allowTypedData": [{ "primaryType": "GiftPermit", "name": "FuelVault", "version": "1" }] } } }
SIGNER_KEYS=
# SIGNER_KEYS_FILE=./keys.json

# Listen port.
PORT=8787
