{
  "name": "kumbaya-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for the Kumbaya DEX API on MegaETH — swap quotes, pools, tokens, stats, and positions.",
  "type": "module",
  "bin": {
    "kumbaya-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "src/openapi.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --loader .json=json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "refresh-spec": "node scripts/refresh-spec.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "kumbaya",
    "megaeth",
    "dex",
    "defi",
    "uniswap-v3"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
